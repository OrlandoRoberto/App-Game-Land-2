<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F2F4F7">

    <LinearLayout
        android:id="@+id/main"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Toolbar -->
        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbarJogo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#00AD89"
            android:minHeight="?attr/actionBarSize"
            app:navigationIcon="@drawable/ic_arrow_back"
            app:titleTextColor="#FFFFFF"/>

        <!-- Imagem do jogo -->
        <ImageView
            android:id="@+id/imgJogo"
            android:layout_width="match_parent"
            android:layout_height="220dp"
            android:scaleType="centerCrop"
            android:background="#1A1A2E"/>

        <!-- Card de informações -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="20dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- Nome do jogo -->
                <TextView
                    android:id="@+id/tvNomeJogo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Nome do Jogo"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="#1A1A2E"/>

                <!-- Gênero -->
                <TextView
                    android:id="@+id/tvGeneroJogo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Ação • Aventura"
                    android:textSize="13sp"
                    android:textColor="#888888"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="16dp"/>

                <!-- Divisor -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#EEEEEE"
                    android:layout_marginBottom="16dp"/>

                <!-- Descrição -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Descrição"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="#1A1A2E"
                    android:layout_marginBottom="8dp"/>

                <TextView
                    android:id="@+id/tvDescricaoJogo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Descrição do jogo aqui..."
                    android:textSize="14sp"
                    android:textColor="#555555"
                    android:lineSpacingExtra="4dp"
                    android:layout_marginBottom="20dp"/>

                <!-- Preços -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="20dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Comprar"
                            android:textSize="12sp"
                            android:textColor="#888888"/>

                        <TextView
                            android:id="@+id/tvPrecoCompra"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="R$ 59,90"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:textColor="#00AD89"/>

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Alugar"
                            android:textSize="12sp"
                            android:textColor="#888888"/>

                        <TextView
                            android:id="@+id/tvPrecoAluguel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="R$ 9,90"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:textColor="#00AD89"/>

                    </LinearLayout>

                </LinearLayout>

                <!-- Botão Comprar -->
                <Button
                    android:id="@+id/btnComprar"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:text="Comprar agora"
                    android:textSize="16sp"
                    android:backgroundTint="#00AD89"
                    app:cornerRadius="12dp"
                    android:layout_marginBottom="12dp"/>

                <!-- Botão Alugar -->
                <Button
                    android:id="@+id/btnAlugar"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:text="Alugar por 7 dias"
                    android:textColor="#00AD89"
                    android:textSize="16sp"
                    android:backgroundTint="@android:color/transparent"
                    app:cornerRadius="12dp"
                    app:strokeColor="#00AD89"
                    app:strokeWidth="1dp"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>