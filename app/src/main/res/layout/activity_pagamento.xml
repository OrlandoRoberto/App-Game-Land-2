<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F2F4F7">

    <LinearLayout
        android:id="@+id/main"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Toolbar -->
        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbarPagamento"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#00AD89"
            android:minHeight="?attr/actionBarSize"
            app:navigationIcon="@drawable/ic_arrow_back"
            app:title="Pagamento"
            app:titleTextColor="#FFFFFF"/>

        <!-- Card resumo -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="20dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Resumo do pedido"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#1A1A2E"
                    android:layout_marginBottom="12dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Jogo"
                        android:textSize="14sp"
                        android:textColor="#888888"/>

                    <TextView
                        android:id="@+id/tvNomeJogoPagamento"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Nome do Jogo"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="#1A1A2E"/>

                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Tipo"
                        android:textSize="14sp"
                        android:textColor="#888888"/>

                    <TextView
                        android:id="@+id/tvTipoPagamento"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Compra"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="#1A1A2E"/>

                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#EEEEEE"
                    android:layout_marginBottom="12dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Total"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#1A1A2E"/>

                    <TextView
                        android:id="@+id/tvValorPagamento"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="R$ 59,90"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="#00AD89"/>

                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Card forma de pagamento -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"
            android:layout_marginBottom="20dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Forma de pagamento"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#1A1A2E"
                    android:layout_marginBottom="16dp"/>

                <!-- Botão Pix -->
                <Button
                    android:id="@+id/btnPix"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="Pagar com Pix"
                    android:textSize="16sp"
                    android:backgroundTint="#00AD89"
                    app:cornerRadius="12dp"
                    android:layout_marginBottom="12dp"/>

                <!-- Botão Cartão -->
                <Button
                    android:id="@+id/btnCartao"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="Pagar com Cartão"
                    android:textColor="#00AD89"
                    android:textSize="16sp"
                    android:backgroundTint="@android:color/transparent"
                    app:cornerRadius="12dp"
                    app:strokeColor="#00AD89"
                    app:strokeWidth="1dp"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>